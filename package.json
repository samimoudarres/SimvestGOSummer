{
  "name": "simvest",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "npx --yes cross-env@7.0.3 SIMVEST_DEV_API_EXTERNAL=1 wait-on tcp:127.0.0.1:3001 && vite",
    "dev:server": "tsx watch server/index.ts",
    "build:legal": "node scripts/buildLegalHtml.mjs",
    "build": "npm run build:legal && tsc && vite build",
    "build:capacitor": "tsc && vite build --mode capacitor",
    "build:capacitor:local": "npx --yes cross-env@7.0.3 CAPACITOR_HTTP_SCHEME=1 tsc && vite build --mode capacitor-dev",
    "cap:sync": "npx --yes cross-env@7.0.3 CAPACITOR_HTTP_SCHEME=1 npm run build:capacitor:local && npx --yes cross-env@7.0.3 CAPACITOR_HTTP_SCHEME=1 npx cap sync",
    "cap:sync:release": "npm run build:capacitor && npx cap sync",
    "cap:copy": "npm run build && npx cap copy",
    "qa:phase7-automation": "npm run build && npm run test:ledger && npm run test:join-invite",
    "preview": "vite preview",
    "test:trade": "tsx server/scripts/verifyTradeFlow.ts",
    "test:ledger": "tsx server/scripts/verifyLedgerInProcess.ts",
    "test:join-invite": "tsx server/scripts/verifyJoinInvite.ts",
    "verify:massive-live": "tsx server/scripts/verifyMassiveLiveLag.ts",
    "icons:generate": "node scripts/generateAppIcons.mjs",
    "admin:render:env": "node scripts/setRenderAdminSecret.mjs",
    "push:complete-setup": "node scripts/completePushSetup.mjs"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "^8.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "web-push": "^3.6.7"
  }
}
