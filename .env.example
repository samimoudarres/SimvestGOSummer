# Copy to `.env` for local dev (never commit `.env`).
# Get a key from https://massive.com (Massive / Polygon-compatible stock API).
MASSIVE_API_KEY=

# ─ Phase 3 production topology ─────────────────────────────────────────────
# After `npm run build`, serve the Vite client from Express alongside `/api` (single HTTPS origin).
# PowerShell: $env:SIMVEST_SERVE_DIST='true'; npx tsx server/index.ts
# SIMVEST_SERVE_DIST=true

# Client env (prefix VITE_) baked in at `vite build` time:
# Public origin where `/api/*` lives — leave unset for dev + same-origin deploys.
# Required for Capacitor when the UI loads from app WebView (non-http origin).
# Example: VITE_API_ORIGIN=https://app.yourdomain.com
# VITE_API_ORIGIN=
#
# Native store builds (recommended): copy `.env.capacitor.example` → `.env.capacitor`
# and run `npm run cap:sync:release` so the bundle always includes VITE_API_ORIGIN.
#
# Emulator / Simulator without VITE_API_ORIGIN: the app defaults to the host machine API
# (Android emulator: http://10.0.2.2:3001 — run `npm run dev:server`).
# Physical devices: set VITE_API_ORIGIN to http://<your-computer-LAN-IP>:3001 (and allow cleartext
# for that host in android/app/src/main/res/xml/network_security_config.xml), or use adb reverse.
#
# Android note: `VITE_API_ORIGIN=http://localhost:3001` (or 127.0.0.1) works on desktop but targets the
# phone itself on device — the app rewrites loopback → 10.0.2.2 automatically on Android native builds.

# Vite dev + preview: where `/api` is proxied (defaults http://127.0.0.1:3001).
# SIMVEST_API_PROXY_TARGET=http://127.0.0.1:3001

# Set to 1 to log snapshot/aggregate freshness + 429 backoffs from `server/massiveClient.ts` (stdout).
# Also run: npm run verify:massive-live
# MASSIVE_LIVE_TRACE=1
#
# Optional Web Push (author “Notify me”). Local dev auto-generates `server/data/vapid-keys.json`.
# Production: set these explicitly (`npx web-push generate-vapid-keys`).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
